{
  "CvAccordion": "<cv-accordion @change=\"onChange\" :align=\"align\" :size=\"size\">\n  <cv-accordion-item v-for=\"n in 4\" :key=\"`acc-item-\\${n}`\" :id=\"n % 2 ? `acc-item-\\${n}` : ''\" :disabled=\"disabledItems.has(n)\">\n    <template v-slot:title>Episode {{n}} </template>\n    <template v-slot:content>\n      <p>Did you hear that? They've shut down the main reactor. We'll be destroyed for sure. This is madness! We're doomed! There'll be no escape for the Princess this time. What's that? R2! R2-D2, where are you? At last! Where have you been? They're heading in this direction.</p>\n    </template>\n  </cv-accordion-item>\n</cv-accordion>\n<div><button @click=\"onToggleEpisode3\">Disable Episode 3</button></div>",
  "CvBreadcrumb": "<cv-breadcrumb v-bind=\"args\">\n  <cv-breadcrumb-item>Breadcrumb 1</cv-breadcrumb-item>\n  <cv-breadcrumb-item>Breadcrumb 2</cv-breadcrumb-item>\n  <cv-breadcrumb-item>Breadcrumb 3</cv-breadcrumb-item>\n</cv-breadcrumb>",
  "CvAspectRatio": "<div class=\"width-container\" :style=\"{ width: args.width + 'px' }\">Container width: {{ args.width }}px\n  <cv-aspect-ratio v-bind=\"args\">\n    Content<br />\n    Width-based only!\n  </cv-aspect-ratio>\n</div>",
  "CvButton": "<cv-button @click=\"onClick\" aria-label=\"button story\" v-bind=\"args\">{{slotArgs.default}}</cv-button>",
  "CvButtonSet": "<cv-button-set v-bind=\"args\">\n  <cv-button>One</cv-button>\n  <cv-button kind=\"secondary\">Two</cv-button>\n  <cv-button kind=\"danger\">Three</cv-button>\n</cv-button-set>",
  "CvIconButton": "<cv-icon-button @click=\"onClick\" v-bind=\"newArgs\" />",
  "CvButtonSkeleton": "<cv-button-skeleton v-bind=\"buttonProps\" />",
  "CvCodeSnippet": "<div class=\"code-snippet-story\" :class=\"{ '${carbonPrefix}--tile': args.light }\">\n  <small v-if=\"args.light\">\n    The snippet container should never be the same color as the page background.<br />\n    Do not use the <cv-code-snippet kind=\"inline\" :light=\"true\" :hide-copy-button=\"true\">light</cv-code-snippet> variant on <cv-code-snippet kind=\"inline\" :light=\"true\" :hide-copy-button=\"true\">$ui-background</cv-code-snippet> or <cv-code-snippet kind=\"inline\" :light=\"true\" :hide-copy-button=\"true\">$ui-02</cv-code-snippet>.\n  </small>\n  <cv-code-snippet v-bind=\"args\" @copy=\"copy\">{{ slotArgs.default }}</cv-code-snippet>\n</div>",
  "CvCheckbox": "<cv-checkbox @change=\"onChange\" v-bind='args' >\n</cv-checkbox>",
  "CvComboBox": "<div style='width: 18.75rem'>\n<cv-combo-box aria-label='Choose a fruit' @change='onChange' @onFilter='onFilter' v-bind='args' >\n</cv-combo-box>\n</div>",
  "CvCopyButton": "<cv-copy-button v-bind=\"args\" @copy=\"copy\" />",
  "CvDatePicker": "<div>\n  <cv-date-picker v-bind=\"args\" :value=\"now\" @change=\"onChange\">\n  </cv-date-picker>\n</div>",
  "CvLink": "<cv-link href='#' v-bind='args'>{{ args.default }}</cv-link>",
  "CvList": "<cv-list v-bind=\"args\">\n  <cv-list-item>List item 1</cv-list-item>\n  <cv-list-item>List item 2</cv-list-item>\n  <cv-list-item>List item 3</cv-list-item>\n</cv-list>",
  "CvLoading": "<div>\n<div class=\"loading-story\">\n<cv-loading @loading-end=\"onLoadingEnd\" v-bind=\"args\" :active=\"isActive\"/>\n</div>\n<button @click=\"makeActive\" :disabled=\"isActive\" style=\"margin-top: 2rem;\">{{buttonLabel}}</button>\n</div>",
  "CvInlineNotification": "<cv-inline-notification v-bind=\"args\" @action=\"onAction\" @close=\"onClose\" />",
  "CvToastNotification": "<cv-toast-notification v-bind=\"args\" @close=\"onClose\" >\n  <template v-if=\"args.titleSlot\" #title>\n    <strong style=\"color: orange; font-size: 1.25rem;\">Custom</strong> <span style=\"color: yellow;\">title</span>\n  </template>\n\n  <template v-if=\"args.subtitleSlot\" #subtitle>\n    Some <strong style=\"color: orange; font-size: 1.25rem;\">custom</strong> <span style=\"color: yellow;\">subtitle</span>\n  </template>\n\n  <template v-if=\"args.captionSlot\" #caption>\n    Some <span style=\"color: green;\">custom</span> <strong style=\"color: orange; font-size: 0.75rem;\">caption</strong>\n  </template>\n\n  <template v-if=\"args.defaultSlot\">\n    Default slot content.\n  </template>\n</cv-toast-notification>",
  "CvNumberInput": "<cv-number-input v-bind=\"args\">\n    <template v-if=\"args['helper-text']\" v-slot:helper-text />\n    <template v-if=\"args['warn-text']\" v-slot:warn-text />\n    <template v-if=\"args['invalid-message']\" v-slot:invalid-message />\n    <template v-if=\"args['label']\" v-slot:label />\n  </cv-number-input>",
  "CvNumberInputSkeleton": "<cv-number-input-skeleton></cv-number-input-skeleton>",
  "CvSkeletonText": "<cv-skeleton-text v-bind=\"args\" />",
  "CvSlider": "<cv-slider v-bind=\"args\" @change=\"onChange\"/>",
  "CvStructuredList": "<div>\n  <cv-structured-list v-bind=\"args\">\n    <template v-slot:headings>\n      <cv-structured-list-heading>\n        Heading 1\n      </cv-structured-list-heading>\n      <cv-structured-list-heading>\n        Heading 2\n      </cv-structured-list-heading>\n      <cv-structured-list-heading>\n        Heading 3\n      </cv-structured-list-heading>\n    </template>\n\n    <template v-slot:items>\n      <cv-structured-list-item v-for=\"({id, data}, index) in DefaultListItems\" :key=\"index\" name=\"group-1\" :value=\"id\" v-model=\"listValue\" @change=\"onChange\">\n        <cv-structured-list-data v-for=\"(itemData, dataIndex) in data\" :key=\"dataIndex\" :no-wrap=\"args.noWrap\">{{ itemData }}</cv-structured-list-data>\n      </cv-structured-list-item>\n    </template>\n  </cv-structured-list>\n\n  <div style=\"margin-top:1rem; background-color: #888888; padding:1rem\" v-if=\"args.withVModel\">\n    <div style=\"font-size: 150%\">Sample interaction</div>\n    <template\n      v-for=\"({id}, vmodelIndex) in DefaultListItems\"\n      :key=\"vmodelIndex\"\n    >\n      <input name=\"listValue\" :id=\"id\" type=\"radio\" @change=\"(ev) => {listValue = ev.target.id}\" :checked=\"id === listValue\" />\n      <label :for=\"id\" style=\"margin-right: 16px;\">{{id}}:</label>\n    </template>\n\n    <div style=\"margin-top: 16px;\">Checked: <span style=\"font-weight: bold;\">{{ listValue }}</span></div>\n  </div>\n</div>",
  "CvSliderSkeleton": "<cv-slider-skeleton />",
  "CvTextInput": "<form @submit.prevent='()=>{}'>\n  <cv-text-input v-bind=\"args\">\n    <template v-if=\"args['helper-text']\" v-slot:helper-text />\n    <template v-if=\"args['warn-text']\" v-slot:warn-text />\n    <template v-if=\"args['invalid-message']\" v-slot:invalid-message />\n  </cv-text-input>\n</form>",
  "CvTextAreaSkeleton": "<cv-text-area-skeleton></cv-text-area-skeleton>",
  "CvTagSkeleton": "<cv-tag-skeleton v-bind=\"args\"></cv-tag-skeleton>",
  "CvTextArea": "<cv-text-area v-bind=\"args\">\n    <template v-if=\"args['helper-text']\" v-slot:helper-text />\n    <template v-if=\"args['invalid-message']\" v-slot:invalid-message />\n  </cv-text-area>",
  "CvTag": "<cv-tag @remove=\"onRemove\" v-bind=\"args\" />",
  "CvDefinitionTooltip": "<cv-definition-tooltip v-bind=\"args\" />",
  "CvToggle": "<cv-toggle @change=\"onChange\" v-bind='args' >\n  <template v-slot:text-left v-if=\"args.use_textLeft\"> 0 </template>\n  <template v-slot:text-right v-if=\"args.use_textRight\"> 1 </template>\n  </cv-toggle>",
  "CvInteractiveTooltip": "<cv-interactive-tooltip v-bind=\"args\">\n    <template #label>\n      Tooltip label\n    </template>\n    <template #trigger>\n      <Filter16 class=\"bx--overflow-menu__icon bx--toolbar-filter-icon\" />\n    </template>\n    <template #content>\n      <p>Lorem ipsum dolor sit amet, consectetur adipisicing elit, seed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>\n      <button class=\"bx--button\">Clicky one</button>\n    </template>\n  </cv-interactive-tooltip>",
  "CvTooltip": "<cv-tooltip v-bind=\"args\" />",
  "CvContent": "<cv-content>Hello main</cv-content>"
}